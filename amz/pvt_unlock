#!/bin/bash
# pvt_unlock [prefix]      - Generate unlock_code_[prefix_]dsn.zip from fastboot
# pvt_unlock -u [prefix]   - Unzip signed file and flash unlock

dsn=$(fastboot getvar serialno 2>&1 | grep 'serialno:' | awk '{print $2}')
if [[ -z "$dsn" ]]; then
    echo "Error: No fastboot device found"
    exit 1
fi

if [[ "$1" == "-u" ]]; then
    rm -f signed_unlock_code*.txt

    zipfile=$(ls signed_unlock_code*_${dsn}.zip 2>/dev/null | head -1)
    if [[ -z "$zipfile" ]]; then
        echo "Error: No signed zip found for $dsn"
        exit 1
    fi
    unzip "$zipfile"

    signed_file=$(ls signed_unlock_code*_${dsn}.txt 2>/dev/null | head -1)
    if [[ -z "$signed_file" ]]; then
        echo "Error: No signed unlock code file found"
        exit 1
    fi

    fastboot flash unlock "$signed_file"

    status=$(fastboot getvar unlock_status 2>&1 | grep 'unlock_status:' | awk '{print $2}')
    echo "$(date '+%Y-%m-%d %H:%M:%S') | $dsn | Unlock rslt: $status" >> unlock.log
    echo "Logged to unlock.log"
    fastboot reboot
else
    tag="${1:+${1}_}${dsn}"
    codefile="unlock_code_${tag}.txt"
    rm -f "$codefile"

    fastboot getvar unlock_code 2>&1 | grep 'unlock_code:' | awk '{printf $2}' > "$codefile"
    zip "unlock_code_${tag}.zip" "$codefile"

    echo "Created unlock_code_${tag}.zip"
    echo "Contents: $(cat "$codefile")"
fi
